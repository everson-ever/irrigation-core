[Unit]
Description=Sistema de irrigação automatizado
After=multi-user.target

[Service]
Type=simple
User=__RUN_USER__
WorkingDirectory="__PROJECT_DIR__"
EnvironmentFile=-/etc/default/sistema-irrigacao
ExecStart="__PROJECT_DIR__/.venv/bin/irrigacao" run
Restart=always
RestartSec=5
TimeoutStopSec=10

[Install]
WantedBy=multi-user.target
